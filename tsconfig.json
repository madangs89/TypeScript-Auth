{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "nodenext",
    "target": "esnext",

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "strict": true,

    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true,

    "esModuleInterop": true
  }
}